#pragma once

// ============================================================
// WiFi Credentials
// ============================================================
#define WIFI_SSID     "your_wifi_ssid"
#define WIFI_PASSWORD "your_wifi_password"

// ============================================================
// AWS IoT Core
// ============================================================
#define AWS_ENDPOINT  "xxxxxxxxxxxxxx-ats.iot.us-east-1.amazonaws.com"
#define AWS_CLIENT_ID "ESP32_Demo"

// ============================================================
// Amazon Root CA 1
// Get from: https://www.amazontrust.com/repository/AmazonRootCA1.pem
// ============================================================
#define ROOT_CA \
"-----BEGIN CERTIFICATE-----\n" \
"<paste Amazon Root CA 1 here>\n" \
"-----END CERTIFICATE-----\n"

// ============================================================
// AWS IoT Device Certificate
// Download from AWS IoT Console when creating a Thing
// ============================================================
#define DEVICE_CERT \
"-----BEGIN CERTIFICATE-----\n" \
"<paste your device certificate here>\n" \
"-----END CERTIFICATE-----\n"

// ============================================================
// AWS IoT Private Key
// Download from AWS IoT Console when creating a Thing
// ============================================================
#define PRIVATE_KEY \
"-----BEGIN RSA PRIVATE KEY-----\n" \
"<paste your private key here>\n" \
"-----END RSA PRIVATE KEY-----\n"
